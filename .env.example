# PhantomStrike local environment template
# Copy values into your shell environment or a private .env loader.
# Do not put real secrets in this example file.

# API server
PHANTOMSTRIKE_HOST=127.0.0.1
PHANTOMSTRIKE_PORT=8888
PHANTOMSTRIKE_API_TOKEN=
DEBUG_MODE=0
PHANTOMSTRIKE_UPDATE_CHECK=0

# Local state and configuration
PHANTOMSTRIKE_DATA_DIR=.phantomstrike_data
PHANTOMSTRIKE_CONFIG_FILE=.phantomstrike_data/config/config_local.json

# LLM backend
PHANTOMSTRIKE_LLM_PROVIDER=ollama
PHANTOMSTRIKE_LLM_MODEL=phantomstrike-ai
PHANTOMSTRIKE_LLM_URL=http://localhost:11434
PHANTOMSTRIKE_LLM_API_KEY=
PHANTOMSTRIKE_LLM_TIMEOUT=600
PHANTOMSTRIKE_LLM_MAX_LOOPS=9
PHANTOMSTRIKE_LLM_THINK=false
PHANTOMSTRIKE_LLM_NUM_CTX=4096
PHANTOMSTRIKE_LLM_NUM_CTX_ANALYZE=16384
PHANTOMSTRIKE_LLM_KEEP_ALIVE=300
PHANTOMSTRIKE_LLM_WARMUP=0

# Optional plugin/tool overrides
PHANTOMSTRIKE_H2CSMUGGLER_PATH=

# Cloud and infrastructure fabric
AWS_REGION=us-east-1
AWS_KEY_NAME=
AWS_LAMBDA_ROLE=
GCP_PROJECT=
GCP_ZONE=us-central1-a
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=phantomstrike-rg
AZURE_LOCATION=eastus
DO_API_TOKEN=
DO_REGION=nyc3
LINODE_API_TOKEN=
LINODE_REGION=us-east
VULTR_API_KEY=
VULTR_REGION=ewr
OCI_COMPARTMENT_ID=
OCI_AD=
OCI_SUBNET_ID=

# DNS and C2 transport providers
DNS_PROVIDER=
CF_ZONE_ID=
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_WORKERS_SUBDOMAIN=workers.dev
ROUTE53_ZONE_ID=
P2P_IFACE=wlan0

# Optional media/social engineering controls
NYXSTRIKE_TTS_ENGINE=elevenlabs
NYXSTRIKE_FACESWAP_BACKEND=roop
NYXSTRIKE_STRICT_OPT_IN=1
